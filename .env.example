# Copy this file to `.env` and fill in your key. `.env` is gitignored.

# Google Gemini API key (https://aistudio.google.com/apikey)
# Used for both embeddings (gemini-embedding-001) and generation.
GEMINI_API_KEY=your-key-here

# --- Qdrant connection (defaults match docker-compose.yml) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=arxiv_papers

# Kaggle credentials are NOT stored here. The Kaggle CLI reads them from
# ~/.kaggle/kaggle.json (download from https://www.kaggle.com/settings -> "Create New Token").
